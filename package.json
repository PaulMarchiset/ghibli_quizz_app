{
  "name": "web-s3",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:network": "nuxt dev --host 0.0.0.0 --port 3000",
    "dev:socket": "tsx server/index.ts",
    "dev:full": "concurrently \"npm:dev:socket\" \"npm:dev\"",
    "dev:full:network": "concurrently \"npm:dev:socket\" \"npm:dev:network\"",
    "generate": "nuxt generate",
    "start": "node .output/server/index.mjs",
    "start:socket": "tsx server/index.ts",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "nuxt": "^4.2.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.56.1"
  }
}
